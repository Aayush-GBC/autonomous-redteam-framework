# ── Anthropic ──────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-api03-REPLACE_ME
CLAUDE_MODEL=claude-sonnet-4-6
PLANNER_MAX_TOKENS=4096

# ── Metasploit RPC ─────────────────────────────────────────────────────────
# Start with: msfrpcd -P msf -S -a 127.0.0.1
MSF_HOST=127.0.0.1
MSF_PORT=55553
MSF_PASSWORD=msf
MSF_SSL=true

# ── Target ─────────────────────────────────────────────────────────────────
# Default target — can be overridden at runtime with:  artasf run --target <ip>
# You do NOT need to edit this file every time you change targets.
TARGET_NETWORK=192.168.56.0/24
ENGAGEMENT_NAME=lab-engagement
# Attacker IP for reverse shell callbacks (LHOST).
# Can be overridden at runtime with:  artasf run --lhost <ip>
LHOST=192.168.56.1

# ── Behaviour ──────────────────────────────────────────────────────────────
MAX_EXPLOIT_ATTEMPTS=3
EXPLOIT_TIMEOUT_SEC=60
# Set to true to run recon + planning without launching any exploits
DRY_RUN=false
# Nmap flags (the runner always appends -oX <output.xml>)
NMAP_FLAGS=-sV -sC --open -T4 --script=http-title,banner
# Max seconds nmap may run before being killed (increase for public/slow hosts)
NMAP_TIMEOUT_SEC=300

# ── Paths ──────────────────────────────────────────────────────────────────
ARTIFACTS_DIR=artifacts
